# .env.development — local development defaults
# Copy to .env and fill in your values. Override with .env.local (never commit .env.local).

NODE_ENV=development
PORT=5000
API_VERSION=v1

DATABASE_URL=postgresql://neondb_owner:npg_yuitV15gEKhw@ep-autumn-butterfly-adi2lc2p.c-2.us-east-1.aws.neon.tech/neondb?sslmode=require
DB_HOST=ep-autumn-butterfly-adi2lc2p.c-2.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=npg_yuitV15gEKhw
# Neon free tier: max ~10 connections; keep pool small
DB_POOL_MAX=5
DB_POOL_MIN=1
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000

JWT_SECRET=dev-jwt-secret-change-me-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-at-least-32-chars
JWT_REFRESH_EXPIRES_IN=30d
# JWT_SECRET_PREVIOUS=   # Uncomment during key rotation

# File Signing — separate secret for file access tokens (must be different from JWT_SECRET)
FILE_SIGNING_SECRET=dev-file-signing-secret-change-me-at-least-32-chars

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

MEETING_PROVIDER=jitsi
MEETING_API_KEY=

CORS_ORIGIN=http://localhost:3000,http://localhost:5173

REDIS_URL=rediss://default:gQAAAAAAAdf9AAIgcDFhMGQxMmFkMGM3MTE0ZjJmOTQ5MWU4ZGVkYTYyZjQ1OA@sweeping-shrimp-120829.upstash.io:6379
REDIS_TLS_ENABLED=true

LOG_LEVEL=debug

SECRETS_PROVIDER=env

SENTRY_DSN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
ENCRYPTION_KEY=change-this-to-a-32-char-or-longer-dev-secret-key
